//This adds ASCII values of characters and mods by table size
int h(String id) {
    int hash = 0;
    for (int ch = 0; ch < id.length(); ch++) {
        hash = (hash + (int)id.charAt(ch)) % m;
    }
    return hash + 1; // ensures index in [1..m]
}

//Chained hash insert (array of nodes)
void hashInsert(String id) {
    ++n; // increment number of items
    store[n].key = (long)n; // assign a key
    int i = h(id); // compute hash
    store[n].next = d[i]; // link to existing chain
    store[n].id = id; // store the string
    d[i] = n; // update head of chain
}
//Each slot d[i] points to the latest inserted node, forming a linked list

//Chained hash search
boolean hashSearch(String id) {
    int i = h(id); // compute hash
    i = d[i]; // get head of chain
    while (i != 0 && !store[i].id.equals(id)) {
        i = store[i].next; // traverse chain
    }
    return store[i].id.equals(id);
}
//Traverses the chain until either the key is found or the chain ends

//Linked list style implementation
//Instead of integer indices, nodes directly reference each other
void hashInsert(long key, String id) {
    node n = new node(key, id);
    int i = hash(id);
    n.next = d[i]; // link to existing node
    d[i] = n; // update head
}
